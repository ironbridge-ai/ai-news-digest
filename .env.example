# Austen — AI News Digest credentials
# Copy this file to ".env" (same folder) and fill in real values.
# The .env file is gitignored and auto-loaded by austen.py at startup.

# Anthropic API key (via the internal LiteLLM proxy)
ANTHROPIC_API_KEY=sk-xxxxxxxxxxxxxxxx

# Base URL of the LiteLLM proxy that serves the model
ANTHROPIC_BASE_URL=http://ib-infra-litellm-01:4000/

# Optional: model to use. Default is eu.anthropic.claude-sonnet-4-6 (Claude,
# EU data residency). Must be a model your key/team can access on the proxy.
# Alternatives: eu.anthropic.claude-opus-4-6-v1 (max quality),
# eu.anthropic.claude-haiku-4-5-20251001-v1:0 (fast/cheap),
# azure-eur-geolocated/gpt-5.5-2 (non-Claude fallback).
# AUSTEN_MODEL=eu.anthropic.claude-sonnet-4-6
