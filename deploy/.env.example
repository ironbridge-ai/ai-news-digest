# Local-dev environment for feedback_server.py. In production these come from
# the Quadlet (non-secret env) + podman secrets (SMTP_*), NOT this file.
#
#   cp deploy/.env.example .env
#   set -a; . ./.env; set +a
#   python3 feedback_server.py

# REQUIRED — the server exits at startup if either is missing (fail-fast).
SMTP_USER=you@ironbridgesg.com
SMTP_PASSWORD=your-m365-app-password

# Optional (defaults shown).
HOST=0.0.0.0
PORT=4097
SMTP_SERVER=smtp.office365.com
DIGEST_SEND_TIME=17:00
AUSTEN_FEEDBACK_RECIPIENT=renato.velasquez@ironbridgesg.com

# Locally the web root + data dir default to the repo dir; in the container
# they are /apps/storage/public and /apps/storage/data.
# AUSTEN_WEB_ROOT=./public
# AUSTEN_DATA_DIR=./data
